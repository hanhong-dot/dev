<?xml version="1.0" encoding="utf-8" ?>
<!--process name="process" project = "common"-->
<process name="process" project="">
    <!-- 属性说明  name    检查页的名称
                 project  继承的项目

    属性说明
                  order_id       表示检查的顺序
                  projectType    表示这个item是这类项目的类型才显示  类型有：TV,FILM,AD,all
                  item_name      表示该item的名字
                  toolTip        表示提示文字
                  process_command 表示调用的处理命令，需传个固定的参数TaskData_Class给方法或类，这样无需重新初始化task_data，这样速度会快很多
                  except_project 表示排除的项目名   建议当projectType为all时候进行排除
                  except_projectType 表示排除的项目类型  建议当projectType为all时候进行排除
    -->
    <process_tab tab_name="文件处理">
        <processItem order_id="1" projectType="all"
                     item_name="生成备份publish文件"
                     toolTip="备份publish文件"
                     process_command="import apps.publish.process.maya.process_sgfile as process_sgfile;reload(process_sgfile);process_sgfile.back_publish(TaskData_Class)"
                     except_project=""
                     except_projectType=""
        />
        <processItem order_id="2" projectType="all"
                     item_name="强制清理"
                     toolTip="清理无用节点和插件"
